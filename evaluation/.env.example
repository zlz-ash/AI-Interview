# ============================================================
#   Ragas 评测环境变量模板
#   使用方式：cp .env.example .env   然后按实际填写
# ============================================================

# ----- 1) 你的 Spring Boot 后端 -----
# 评测脚本会先登录拿 accessToken，再调 /api/rag-chat/evaluate
BACKEND_BASE_URL=http://localhost:8080
BACKEND_USERNAME=ash
BACKEND_PASSWORD=zhao197810

# ----- 0) 网络代理（建议固定到 7897）-----
# 为空=不走代理；有值=HTTP/HTTPS/ALL 都走该代理
# 推荐：本机代理端口 7897
EVAL_PROXY_URL=http://127.0.0.1:7897
# 本地后端直连，避免 localhost 被代理导致连接失败
NO_PROXY=localhost,127.0.0.1

# 被评测的知识库 ID 列表（英文逗号分隔），例如 1,2
EVAL_KB_IDS=1
# 检索模式，可选 HYBRID / VECTOR；评测一般跟线上一致
EVAL_RETRIEVAL_MODE=HYBRID

# ----- 2) 评测用的「裁判 LLM」 -----
# Ragas 的所有指标都要 LLM 打分。以下变量走 OpenAI 兼容协议。
# 推荐优先用 SiliconFlow（与业务同源，成本低）：
#   JUDGE_BASE_URL=https://api.siliconflow.cn/v1
#   JUDGE_MODEL=Pro/deepseek-ai/DeepSeek-V3
# 或者用官方 OpenAI（评分最稳）：
#   JUDGE_BASE_URL=https://api.openai.com/v1
#   JUDGE_MODEL=gpt-4o-mini
JUDGE_BASE_URL=https://api.siliconflow.cn/v1
JUDGE_API_KEY=sk-pxxfybxrhdlqzfbdodgwyexoeueewmqlhiqegcisskfgspsx
JUDGE_MODEL=Pro/zai-org/GLM-5.1
# 可选：打分温度；0 最稳
JUDGE_TEMPERATURE=0

# ----- 3) 评测用的 Embedding（给 ResponseRelevancy 等指标用）-----
# 强烈建议保持与后端业务相同，这样测出来更贴近真实体验：
#   EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   EMBED_MODEL=text-embedding-v3
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
EMBED_API_KEY=sk-02ae141b576c4c32b5f47e8d3d812f93
EMBED_MODEL=text-embedding-v3
# 对 OpenAI-compatible 网关建议 false，避免 token-id 输入导致 400
EMBED_CHECK_CTX_LENGTH=false
# 兼容网关建议 float
EMBED_ENCODING_FORMAT=float

# ----- 4) 运行控制 -----
# 并发度（同时跑多少条样本的评分）；过大容易被 LLM 限流
RAGAS_MAX_WORKERS=4
# 是否打印逐条样本的 answer/contexts（调试用）
DEBUG_PRINT_SAMPLES=false
